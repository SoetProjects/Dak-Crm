generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  OFFICE
  FIELD_WORKER

  @@map("user_role")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST

  @@map("lead_status")
}

enum RequestType {
  LEAK
  RENOVATION
  INSPECTION
  MAINTENANCE
  NEW_BUILD
  OTHER

  @@map("request_type")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("quote_status")
}

enum JobType {
  LEAK
  BITUMEN_ROOF
  ROOF_RENOVATION
  INSPECTION
  MAINTENANCE
  NEW_BUILD
  OTHER

  @@map("job_type")
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD

  @@map("job_status")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED

  @@map("invoice_status")
}

enum PlanningItemType {
  JOB
  MEETING
  ABSENCE
  TRAINING
  OTHER

  @@map("planning_item_type")
}

enum TimeEntryType {
  WORK
  TRAVEL
  BREAK

  @@map("time_entry_type")
}

enum MaterialUnit {
  M2
  M
  PIECE
  KG
  L
  HOUR
  SET

  @@map("material_unit")
}

enum IntegrationProvider {
  EXACT
  SNELSTART
  MONEYBIRD
  TWINFIELD
  AFAS
  OTHER

  @@map("integration_provider")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR

  @@map("integration_status")
}

// ─────────────────────────────────────────────
// Core tables
// ─────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  kvkNumber String?  @map("kvk_number")
  vatNumber String?  @map("vat_number")
  address   String?
  city      String?
  phone     String?
  email     String?
  website   String?
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  customers     Customer[]
  leads         Lead[]
  quotes        Quote[]
  jobs          Job[]
  planningItems PlanningItem[]
  timeEntries   TimeEntry[]
  materials     Material[]
  invoices      Invoice[]
  integrations  Integration[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supabaseId   String?  @unique @map("supabase_id")
  email        String   @unique
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  jobAssignments JobAssignment[]
  jobNotes       JobNote[]
  jobPhotos      JobPhoto[]
  timeEntries    TimeEntry[]
  planningItems  PlanningItem[]

  @@index([companyId, role])
  @@map("users")
}

model Customer {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  contactPerson  String?  @map("contact_person")
  phone          String?
  email          String?
  billingAddress String?  @map("billing_address")
  billingCity    String?  @map("billing_city")
  billingZip     String?  @map("billing_zip")
  serviceAddress String?  @map("service_address")
  serviceCity    String?  @map("service_city")
  serviceZip     String?  @map("service_zip")
  kvkNumber      String?  @map("kvk_number")
  vatNumber      String?  @map("vat_number")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  leads    Lead[]
  quotes   Quote[]
  jobs     Job[]
  invoices Invoice[]

  @@index([companyId, name])
  @@map("customers")
}

model Lead {
  id          String      @id @default(uuid())
  companyId   String      @map("company_id")
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String?     @map("customer_id")
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name        String
  phone       String?
  email       String?
  address     String?
  city        String?
  requestType RequestType @map("request_type")
  status      LeadStatus  @default(NEW)
  notes       String?
  source      String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  quotes Quote[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("leads")
}

// ─────────────────────────────────────────────
// Quotes
// ─────────────────────────────────────────────

model Quote {
  id           String      @id @default(uuid())
  companyId    String      @map("company_id")
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId   String      @map("customer_id")
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  leadId       String?     @map("lead_id")
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quoteNumber  String      @map("quote_number")
  status       QuoteStatus @default(DRAFT)
  subject      String?
  notes        String?
  validUntil   DateTime?   @map("valid_until")
  totalAmount  Decimal     @default(0) @db.Decimal(12, 2) @map("total_amount")
  vatAmount    Decimal     @default(0) @db.Decimal(12, 2) @map("vat_amount")
  vatRate      Decimal     @default(21) @db.Decimal(5, 2) @map("vat_rate")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  lines    QuoteLine[]
  jobs     Job[]
  invoices Invoice[]

  @@unique([companyId, quoteNumber])
  @@index([companyId, status])
  @@map("quotes")
}

model QuoteLine {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  quoteId     String  @map("quote_id")
  quote       Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(12, 2)
  unit        String  @default("st")
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  total       Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(21) @db.Decimal(5, 2) @map("vat_rate")
  sortOrder   Int     @default(0) @map("sort_order")

  @@index([companyId, quoteId])
  @@map("quote_lines")
}

// ─────────────────────────────────────────────
// Jobs (work orders)
// ─────────────────────────────────────────────

model Job {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId     String    @map("customer_id")
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quoteId        String?   @map("quote_id")
  quote          Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  jobNumber      String?   @map("job_number")
  title          String
  description    String?
  address        String?
  city           String?
  jobType        JobType   @map("job_type")
  status         JobStatus @default(PLANNED)
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")
  actualStart    DateTime? @map("actual_start")
  actualEnd      DateTime? @map("actual_end")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  assignments   JobAssignment[]
  photos        JobPhoto[]
  jobNotes      JobNote[]
  timeEntries   TimeEntry[]
  jobMaterials  JobMaterial[]
  planningItems PlanningItem[]
  invoices      Invoice[]

  @@index([companyId, status])
  @@index([companyId, scheduledStart])
  @@map("jobs")
}

model JobAssignment {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  jobId      String   @map("job_id")
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")
  isLead     Boolean  @default(false) @map("is_lead")

  @@unique([jobId, userId])
  @@index([companyId, userId])
  @@index([companyId, jobId])
  @@map("job_assignments")
}

model JobNote {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  jobId     String   @map("job_id")
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId, jobId, createdAt])
  @@map("job_notes")
}

model JobPhoto {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  jobId        String   @map("job_id")
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedById String?  @map("uploaded_by_id")
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  fileKey      String   @map("file_key")
  fileUrl      String?  @map("file_url")
  caption      String?
  takenAt      DateTime? @map("taken_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([companyId, jobId, createdAt])
  @@map("job_photos")
}

// ─────────────────────────────────────────────
// Planning
// ─────────────────────────────────────────────

model PlanningItem {
  id          String           @id @default(uuid())
  companyId   String           @map("company_id")
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId       String?          @map("job_id")
  job         Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  userId      String?          @map("user_id")
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        PlanningItemType @default(JOB)
  title       String
  description String?
  startAt     DateTime         @map("start_at")
  endAt       DateTime         @map("end_at")
  allDay      Boolean          @default(false) @map("all_day")
  color       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([companyId, startAt])
  @@index([companyId, userId, startAt])
  @@map("planning_items")
}

// ─────────────────────────────────────────────
// Time registration
// ─────────────────────────────────────────────

model TimeEntry {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId       String        @map("job_id")
  job         Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  type        TimeEntryType @default(WORK)
  startedAt   DateTime      @map("started_at")
  endedAt     DateTime?     @map("ended_at")
  minutes     Int?
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([companyId, jobId])
  @@index([companyId, userId, startedAt])
  @@map("time_entries")
}

// ─────────────────────────────────────────────
// Materials
// ─────────────────────────────────────────────

model Material {
  id          String       @id @default(uuid())
  companyId   String       @map("company_id")
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sku         String?
  unit        MaterialUnit @default(PIECE)
  costPrice   Decimal?     @db.Decimal(12, 2) @map("cost_price")
  salesPrice  Decimal?     @db.Decimal(12, 2) @map("sales_price")
  vatRate     Decimal      @default(21) @db.Decimal(5, 2) @map("vat_rate")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  jobMaterials JobMaterial[]

  @@index([companyId, name])
  @@map("materials")
}

model JobMaterial {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  jobId        String    @map("job_id")
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  materialId   String?   @map("material_id")
  material     Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  description  String
  quantity     Decimal   @db.Decimal(12, 2)
  unit         String    @default("st")
  unitCost     Decimal   @default(0) @db.Decimal(12, 2) @map("unit_cost")
  unitPrice    Decimal   @default(0) @db.Decimal(12, 2) @map("unit_price")
  total        Decimal   @default(0) @db.Decimal(12, 2)
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([companyId, jobId])
  @@map("job_materials")
}

// ─────────────────────────────────────────────
// Invoices
// ─────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  companyId      String        @map("company_id")
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId     String        @map("customer_id")
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  jobId          String?       @map("job_id")
  job            Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId        String?       @map("quote_id")
  quote          Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  invoiceNumber  String        @map("invoice_number")
  status         InvoiceStatus @default(DRAFT)
  subject        String?
  notes          String?
  invoiceDate    DateTime      @default(now()) @map("invoice_date")
  dueDate        DateTime?     @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  totalAmount    Decimal       @default(0) @db.Decimal(12, 2) @map("total_amount")
  vatAmount      Decimal       @default(0) @db.Decimal(12, 2) @map("vat_amount")
  externalRef    String?       @map("external_ref")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  lines InvoiceLine[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  invoiceId   String  @map("invoice_id")
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(12, 2)
  unit        String  @default("st")
  unitPrice   Decimal @db.Decimal(12, 2) @map("unit_price")
  total       Decimal @db.Decimal(12, 2)
  vatRate     Decimal @default(21) @db.Decimal(5, 2) @map("vat_rate")
  sortOrder   Int     @default(0) @map("sort_order")

  @@index([companyId, invoiceId])
  @@map("invoice_lines")
}

// ─────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────

model Integration {
  id           String              @id @default(uuid())
  companyId    String              @map("company_id")
  company      Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider     IntegrationProvider
  status       IntegrationStatus   @default(INACTIVE)
  accessToken  String?             @map("access_token")
  refreshToken String?             @map("refresh_token")
  tokenExpiry  DateTime?           @map("token_expiry")
  settings     Json?
  lastSyncAt   DateTime?           @map("last_sync_at")
  lastError    String?             @map("last_error")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@unique([companyId, provider])
  @@index([companyId, status])
  @@map("integrations")
}
