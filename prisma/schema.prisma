generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  OFFICE
  FIELD_WORKER
}

enum CustomerType {
  PRIVATE
  BUSINESS
  HOA
  CONTRACTOR
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT_PLANNED
  QUOTED
  WON
  LOST
}

enum RequestType {
  LEAK
  RENOVATION
  INSPECTION
  BITUMEN_ROOF
  ROOF_TERRACE
  OTHER
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum JobType {
  LEAK
  INSPECTION
  BITUMEN_ROOF
  ROOF_RENOVATION
  ROOF_TERRACE
  MAINTENANCE
  OTHER
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  WAITING_FOR_MATERIAL
  WAITING_FOR_WEATHER
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PlanningItemType {
  JOB
  INSPECTION
  QUOTE_VISIT
  MAINTENANCE
  BLOCKED
}

enum TimeEntryType {
  WORK
  TRAVEL
  BREAK
}

enum MaterialUnit {
  M2
  M1
  STUK
  UUR
  DAG
  KG
  L
  POST
}

enum IntegrationProvider {
  MOLLIE
  OPENWEATHER
  POSTCODE_API
  EMAIL
  SNELSTART
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
}

// ─────────────────────────────────────────────
// Company
// ─────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  kvkNumber String?
  vatNumber String?
  address   String?
  postalCode String?
  city      String?
  phone     String?
  email     String?
  website   String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  customers        Customer[]
  leads            Lead[]
  quotes           Quote[]
  jobs             Job[]
  planningItems    PlanningItem[]
  timeEntries      TimeEntry[]
  materials        Material[]
  invoices         Invoice[]
  integrations     Integration[]
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supabaseId  String?  @unique
  email       String   @unique
  firstName   String
  lastName    String
  phone       String?
  role        UserRole
  isActive    Boolean  @default(true)
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobAssignments JobAssignment[]
  jobNotes       JobNote[]
  jobPhotos      JobPhoto[]
  timeEntries    TimeEntry[]
  planningItems  PlanningItem[]

  @@index([companyId, role])
}

// ─────────────────────────────────────────────
// Customer
// ─────────────────────────────────────────────

model Customer {
  id                   String       @id @default(uuid())
  companyId            String
  company              Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerType         CustomerType @default(PRIVATE)
  name                 String
  contactPerson        String?
  phone                String?
  email                String?
  billingAddress       String?
  billingPostalCode    String?
  billingCity          String?
  serviceAddress       String?
  servicePostalCode    String?
  serviceCity          String?
  kvkNumber            String?
  vatNumber            String?
  notes                String?
  isActive             Boolean      @default(true)
  // Accounting sync fields (used by SnelStart and future integrations)
  externalAccountingId String?
  accountingSyncStatus String       @default("not_synced")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  leads    Lead[]
  quotes   Quote[]
  jobs     Job[]
  invoices Invoice[]

  @@index([companyId, name])
  @@index([companyId, customerType])
  @@index([companyId, accountingSyncStatus])
}

// ─────────────────────────────────────────────
// Lead
// ─────────────────────────────────────────────

model Lead {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  name        String
  phone       String?
  email       String?
  address     String?
  postalCode  String?
  city        String?
  requestType RequestType
  status      LeadStatus  @default(NEW)
  source      String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  quotes Quote[]
  jobs   Job[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
}

// ─────────────────────────────────────────────
// Quote
// ─────────────────────────────────────────────

model Quote {
  id          String      @id @default(uuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  leadId      String?
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quoteNumber String
  title       String      @default("")
  status      QuoteStatus @default(DRAFT)
  subtotal    Decimal     @default(0) @db.Decimal(12, 2)
  vatPercentage Decimal   @default(21) @db.Decimal(5, 2)
  vatAmount   Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount Decimal     @default(0) @db.Decimal(12, 2)
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lines    QuoteLine[]
  jobs     Job[]
  invoices Invoice[]

  @@unique([companyId, quoteNumber])
  @@index([companyId, status])
}

model QuoteLine {
  id            String  @id @default(uuid())
  companyId     String
  quoteId       String
  quote         Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal @db.Decimal(12, 3)
  unit          String  @default("stuk")
  unitPrice     Decimal @db.Decimal(12, 2)
  vatPercentage Decimal @default(21) @db.Decimal(5, 2)
  totalAmount   Decimal @db.Decimal(12, 2)
  sortOrder     Int     @default(0)

  @@index([companyId, quoteId])
}

// ─────────────────────────────────────────────
// Job (werkbon)
// ─────────────────────────────────────────────

model Job {
  id              String    @id @default(uuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quoteId         String?
  quote           Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  jobNumber       String?
  title           String
  description     String?
  jobType         JobType
  status          JobStatus @default(PLANNED)
  address         String?
  postalCode      String?
  city            String?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  completedAt     DateTime?
  internalNotes   String?
  customerNotes   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignments  JobAssignment[]
  jobNotes     JobNote[]
  photos       JobPhoto[]
  timeEntries  TimeEntry[]
  jobMaterials JobMaterial[]
  planningItems PlanningItem[]
  invoices     Invoice[]

  @@index([companyId, status])
  @@index([companyId, scheduledStart])
}

model JobAssignment {
  id         String   @id @default(uuid())
  companyId  String
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())
  isLead     Boolean  @default(false)

  @@unique([jobId, userId])
  @@index([companyId, userId])
  @@index([companyId, jobId])
}

model JobNote {
  id        String   @id @default(uuid())
  companyId String
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, jobId, createdAt])
}

model JobPhoto {
  id           String    @id @default(uuid())
  companyId    String
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  fileKey      String
  fileUrl      String?
  caption      String?
  takenAt      DateTime?
  createdAt    DateTime  @default(now())

  @@index([companyId, jobId])
}

// ─────────────────────────────────────────────
// Planning
// ─────────────────────────────────────────────

model PlanningItem {
  id          String           @id @default(uuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId       String?
  job         Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        PlanningItemType @default(JOB)
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean          @default(false)
  color       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([companyId, startAt])
  @@index([companyId, userId, startAt])
}

// ─────────────────────────────────────────────
// Time entries
// ─────────────────────────────────────────────

model TimeEntry {
  id        String        @id @default(uuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  type      TimeEntryType @default(WORK)
  startedAt DateTime
  endedAt   DateTime?
  minutes   Int?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([companyId, jobId])
  @@index([companyId, userId, startedAt])
}

// ─────────────────────────────────────────────
// Materials
// ─────────────────────────────────────────────

model Material {
  id            String       @id @default(uuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  category      String?
  unit          MaterialUnit @default(STUK)
  defaultPrice  Decimal?     @db.Decimal(12, 2)
  stockQuantity Decimal?     @db.Decimal(12, 3)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  jobMaterials JobMaterial[]

  @@index([companyId, name])
  @@index([companyId, category])
}

model JobMaterial {
  id          String    @id @default(uuid())
  companyId   String
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  materialId  String?
  material    Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  description String
  quantity    Decimal   @db.Decimal(12, 3)
  unit        String    @default("stuk")
  unitPrice   Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount Decimal   @default(0) @db.Decimal(12, 2)
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId, jobId])
}

// ─────────────────────────────────────────────
// Invoice
// ─────────────────────────────────────────────

model Invoice {
  id                   String        @id @default(uuid())
  companyId            String
  company              Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  jobId                String?
  job                  Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId              String?
  quote                Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  invoiceNumber        String
  status               InvoiceStatus @default(DRAFT)
  subtotal             Decimal       @default(0) @db.Decimal(12, 2)
  vatPercentage        Decimal       @default(21) @db.Decimal(5, 2)
  vatAmount            Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal       @default(0) @db.Decimal(12, 2)
  invoiceDate          DateTime      @default(now())
  dueDate              DateTime?
  paidAt               DateTime?
  notes                String?
  externalRef          String?
  // Accounting sync fields (used by SnelStart and future integrations)
  externalAccountingId String?
  accountingSyncStatus String        @default("not_synced")
  accountingSyncError  String?
  syncedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  lines InvoiceLine[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status])
  @@index([companyId, dueDate])
  @@index([companyId, accountingSyncStatus])
}

model InvoiceLine {
  id            String  @id @default(uuid())
  companyId     String
  invoiceId     String
  invoice       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal @db.Decimal(12, 3)
  unit          String  @default("stuk")
  unitPrice     Decimal @db.Decimal(12, 2)
  vatPercentage Decimal @default(21) @db.Decimal(5, 2)
  totalAmount   Decimal @db.Decimal(12, 2)
  sortOrder     Int     @default(0)

  @@index([companyId, invoiceId])
}

// ─────────────────────────────────────────────
// Integrations
// ─────────────────────────────────────────────

model Integration {
  id                   String              @id @default(uuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider             IntegrationProvider
  name                 String?
  status               IntegrationStatus   @default(INACTIVE)
  // TODO: Replace with proper encrypted credentials before storing real keys
  encryptedCredentials String?
  accessToken          String?
  refreshToken         String?
  tokenExpiry          DateTime?
  config               Json?
  lastSyncAt           DateTime?
  lastError            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  logs IntegrationLog[]

  @@unique([companyId, provider])
  @@index([companyId, status])
}

model IntegrationLog {
  id            String       @id @default(uuid())
  companyId     String
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  type          String
  direction     String
  entityType    String?
  entityId      String?
  status        String
  message       String?
  payload       Json?
  createdAt     DateTime     @default(now())

  @@index([companyId, integrationId])
  @@index([companyId, createdAt])
  @@index([companyId, entityType, entityId])
}
